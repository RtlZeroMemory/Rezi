{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "include": [
        "packages/core/src/**/*.ts",
        "packages/node/src/**/*.ts",
        "packages/jsx/src/**/*.ts",
        "packages/jsx/src/**/*.tsx",
        "packages/testkit/src/**/*.ts"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "error"
          },
          "style": {
            "noNonNullAssertion": "error",
            "useImportType": "error"
          },
          "suspicious": {
            "noAsyncPromiseExecutor": "error",
            "noExplicitAny": "error"
          }
        }
      }
    },
    {
      "include": [
        "packages/core/src/**/__tests__/**",
        "packages/node/src/**/__tests__/**",
        "packages/node/src/**/__e2e__/**",
        "packages/jsx/src/**/__tests__/**",
        "packages/testkit/src/**/__tests__/**"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "include": ["packages/core/src/drawlist/writers.gen.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      ".venv-docs/**",
      ".artifacts/**",
      "out/**",
      "benchmarks/local-*/**",
      "**/dist/**",
      "**/node_modules/**",
      "**/target/**",
      "**/*.node",
      "**/vendor/**",
      "**/debug-traces/**",
      "**/Screens/**"
    ]
  }
}
